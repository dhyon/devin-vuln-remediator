# Copy to .env for real mode. Do not commit real secrets.
APP_MODE=real
DEVIN_MODE=real
GITHUB_MODE=real
DATABASE_PATH=data/remediator-real.db

GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string
GITHUB_TOKEN=replace-with-a-least-privilege-token
GITHUB_API_BASE_URL=https://api.github.com

DEVIN_API_KEY=replace-with-your-devin-api-key
DEVIN_ORG_ID=replace-with-your-devin-org-id
DEVIN_API_BASE_URL=https://api.devin.ai
DEVIN_REPOS=your-github-user/superset
DEVIN_MAX_ACU_LIMIT=
DEVIN_ENTERPRISE_ANALYTICS=false

TRIGGER_LABEL=devin-remediate
POLL_LIMIT=25
ENGINEER_HOURS_PER_REMEDIATION=2.0
ENGINEER_HOURLY_COST=150.0
